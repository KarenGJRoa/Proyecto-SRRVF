{
  "info": {
    "_postman_id": "sspr-api-final",
    "name": "SSPR API - Final",
    "description": "Coleccion Postman para SSPR: login, pedidos, tracking y repartidores.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/"
      }
    },
    {
      "name": "Auth - Login Alias /api/login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@sspr.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": "{{base_url}}/api/login"
      }
    },
    {
      "name": "Auth - Login /api/auth/login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@sspr.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": "{{base_url}}/api/auth/login"
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/api/auth/me"
      }
    },
    {
      "name": "Orders - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/api/orders"
      }
    },
    {
      "name": "Orders - Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.order?.id) pm.collectionVariables.set('order_id', json.order.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"origen\": \"Lima\",\n  \"destino\": \"Callao\",\n  \"cliente\": \"Cliente Demo\",\n  \"descripcion\": \"Pedido creado desde Postman\"\n}"
        },
        "url": "{{base_url}}/api/orders"
      }
    },
    {
      "name": "Orders - Get By Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/api/orders/{{order_id}}"
      }
    },
    {
      "name": "Orders - Update Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"estado\": \"En tránsito\"\n}"
        },
        "url": "{{base_url}}/api/orders/{{order_id}}/estado"
      }
    },
    {
      "name": "Tracking - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/api/tracking"
      }
    },
    {
      "name": "Tracking - Detail",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/api/tracking/{{order_id}}"
      }
    },
    {
      "name": "Repartidores - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/api/repartidores"
      }
    },
    {
      "name": "Repartidores - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Juan Perez\",\n  \"telefono\": \"999888777\",\n  \"placa\": \"ABC-123\",\n  \"estado\": \"Disponible\"\n}"
        },
        "url": "{{base_url}}/api/repartidores"
      }
    }
  ]
}
